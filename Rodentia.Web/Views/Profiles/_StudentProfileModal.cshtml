@model Rodentia.Core.Models.Profiles.StudentProfileDto
@{
    var initials = $"{Model.FirstName.FirstOrDefault()}{Model.LastName.FirstOrDefault()}".ToUpper();
}

<div class="modal-header student-profile-modal-header">
    <h5 class="modal-title student-profile-modal-title">Профіль учня</h5>
    <button type="button" class="btn-close btn-close-white student-profile-modal-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body student-profile-modal-body">
    <div class="student-profile-layout">
        <div class="student-profile-avatar-wrap">
            @if (!string.IsNullOrWhiteSpace(Model.AvatarPath))
            {
                <img src="@Model.AvatarPath" alt="Фото профілю" class="student-profile-avatar" />
            }
            else
            {
                <div class="student-profile-avatar-placeholder">
                    @initials
                </div>
            }
        </div>

        <div class="student-profile-main">
            <div class="student-profile-name">
                @Model.FirstName @Model.LastName
            </div>

            <div class="student-profile-role">
                Учень
            </div>

            <div class="student-profile-grid">
                <div>
                    @if (!string.IsNullOrEmpty(Model.Email))
                    {
                        <div class="student-profile-field">
                            <div class="student-profile-label">Email</div>
                            <div class="student-profile-email">
                                @Model.Email
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.StudentCode))
                    {
                        <div class="student-profile-field">
                            <div class="student-profile-label">Код учня</div>
                            <div class="student-profile-code">
                                @Model.StudentCode
                            </div>
                        </div>
                    }
                </div>

                <div>
                    @if (!string.IsNullOrEmpty(Model.StudentClass))
                    {
                        <div class="student-profile-field">
                            <div class="student-profile-label">Клас</div>
                            <div class="student-profile-value student-profile-value--strong">
                                @Model.StudentClass
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.PhoneNumber))
                    {
                        <div class="student-profile-field">
                            <div class="student-profile-label">Номер телефону</div>
                            <div class="student-profile-value">
                                <a href="tel:@Model.PhoneNumber" class="student-profile-phone-link">
                                    @Model.PhoneNumber
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal-footer student-profile-modal-footer">
    <button type="button" class="btn student-profile-close-btn" data-bs-dismiss="modal">
        Закрити
    </button>
</div>


