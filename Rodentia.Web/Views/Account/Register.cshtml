@using Rodentia.Core.Entities
@model RegisterViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Реєстрація";
}
<form asp-action="Register" method="post" id="registerForm">
    <div asp-validation-summary="All" class="text-danger small mb-3 text-start"></div>

    <div class="d-flex align-items-center justify-content-center mb-4">
        <span class="role-label">Хто ви?</span>
        <div class="d-flex gap-2">
            <button type="button" class="role-btn active" data-role="@UserRole.Student">Учень</button>
            <button type="button" class="role-btn" data-role="@UserRole.Teacher">Викладач</button>
        </div>
        <input type="hidden" asp-for="Role" id="selectedRole" value="@UserRole.Student" />
    </div>

    <div class="row g-2 mb-3">
        <div class="col-6">
            <input asp-for="FirstName" class="form-control bg-light border-0 py-2 auth-input"
                   placeholder="Ім'я" />
        </div>
        <div class="col-6">
            <input asp-for="LastName" class="form-control bg-light border-0 py-2 auth-input"
                   placeholder="Прізвище" />
        </div>
    </div>

    <div class="mb-3">
        <input asp-for="Email" class="form-control bg-light border-0 py-2 auth-input"
               placeholder="Email" />
    </div>
    <div class="mb-3">
        <input asp-for="Password" type="password" class="form-control bg-light border-0 py-2 auth-input"
               placeholder="Пароль" />
    </div>
    <div class="mb-4">
        <input asp-for="ConfirmPassword" type="password" class="form-control bg-light border-0 py-2 auth-input"
               placeholder="Підтвердіть пароль" />
    </div>

    <button type="submit" class="btn w-100 py-2 mb-3 auth-submit-btn">
        Зареєструватися
    </button>

    <div class="text-center">
        <span class="small text-muted">Вже маєте акаунт? </span>
        <a href="/Account/Login" class="text-decoration-none small auth-link">Увійти</a>
    </div>
</form>
