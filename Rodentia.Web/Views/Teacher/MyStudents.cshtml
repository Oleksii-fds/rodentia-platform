@model IEnumerable<Rodentia.Core.Entities.User>
@{
    ViewData["Title"] = "Мої учні";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center my-4">
        <h2 class="fw-bold m-0">Мої учні</h2>
        
        <form asp-controller="Teacher" asp-action="AddStudent" method="post" class="d-flex gap-2">
            <input name="identifier" class="form-control" placeholder="Email або код учня..." style="width: 280px; border-radius: 10px;" required />
            <button type="submit" class="btn btn-warning text-white fw-bold px-4" style="border-radius: 10px;">
                Додати учня
            </button>
        </form>
    </div>

    <div class="card border-0 shadow-sm" style="border-radius: 15px;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3">Прізвище та ім'я</th>
                            <th>Email</th>
                            <th>Унікальний код</th>
                            <th class="text-end pe-4">Дії</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    У вашому списку ще немає жодного учня
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var student in Model)
                            {
                                <tr>
                                    <td class="ps-4 py-3 fw-bold">@student.FirstName @student.LastName</td>
                                    <td>@student.Email</td>
                                    <td>
                                        <span class="badge bg-light text-dark border px-2 py-1">
                                            @student.UniqueCode
                                        </span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <form asp-action="RemoveStudent" method="post">
                                            <input type="hidden" name="studentId" value="@student.Id" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm border-0">
                                                <i class="bi bi-trash-fill fs-5"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>