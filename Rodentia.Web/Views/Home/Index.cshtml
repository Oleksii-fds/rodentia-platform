@{
    ViewData["Title"] = "Home Page";
}

<div class="home-page">
    <section class="home-hero">
        <div class="home-hero__badge">Rodentia Platform</div>
        <h1 class="home-hero__title">Панель часу та часових поясів</h1>
        <p class="home-hero__subtitle">
            Відстежуйте локальний час і швидко порівнюйте його з іншими країнами для зручного планування занять.
        </p>
    </section>

    <section class="home-cards">
        <article class="home-card">
            <h5 class="home-card__title">Ваша країна і час</h5>
            <div class="home-card__row">
                <span class="home-card__label">Країна/місто</span>
                <span class="home-card__value">@ViewData["VisitorLocation"]</span>
            </div>
            <div class="home-card__row">
                <span class="home-card__label">Часовий пояс</span>
                <span class="home-card__value" id="visitor-timezone">@ViewData["VisitorTimeZone"]</span>
            </div>
            <div class="home-card__row home-card__row--time">
                <span class="home-card__label">Поточний час</span>
                <span class="home-card__time" id="visitor-local-time">@ViewData["VisitorLocalTime"]</span>
            </div>
        </article>

        <article class="home-card">
            <h5 class="home-card__title">Час інших країн</h5>
            <div class="home-card__controls">
                <select id="timezone-select" class="form-select">
                    <option value="Europe/Kyiv">Україна (Europe/Kyiv)</option>
                    <option value="Europe/Warsaw">Польща (Europe/Warsaw)</option>
                    <option value="Europe/Prague">Чехія (Europe/Prague)</option>
                    <option value="Europe/Vienna">Австрія (Europe/Vienna)</option>
                    <option value="Europe/Budapest">Угорщина (Europe/Budapest)</option>
                    <option value="Europe/Bucharest">Румунія (Europe/Bucharest)</option>
                    <option value="Europe/Sofia">Болгарія (Europe/Sofia)</option>
                    <option value="Europe/Athens">Греція (Europe/Athens)</option>
                    <option value="Europe/Vilnius">Литва (Europe/Vilnius)</option>
                    <option value="Europe/Riga">Латвія (Europe/Riga)</option>
                    <option value="Europe/Tallinn">Естонія (Europe/Tallinn)</option>
                    <option value="Europe/Chisinau">Молдова (Europe/Chisinau)</option>
                    <option value="Europe/Zurich">Швейцарія (Europe/Zurich)</option>
                    <option value="Europe/Brussels">Бельгія (Europe/Brussels)</option>
                    <option value="Europe/Amsterdam">Нідерланди (Europe/Amsterdam)</option>
                    <option value="Europe/Luxembourg">Люксембург (Europe/Luxembourg)</option>
                    <option value="Europe/Copenhagen">Данія (Europe/Copenhagen)</option>
                    <option value="Europe/Oslo">Норвегія (Europe/Oslo)</option>
                    <option value="Europe/Stockholm">Швеція (Europe/Stockholm)</option>
                    <option value="Europe/Helsinki">Фінляндія (Europe/Helsinki)</option>
                    <option value="Europe/Dublin">Ірландія (Europe/Dublin)</option>
                    <option value="Europe/Lisbon">Португалія (Europe/Lisbon)</option>
                    <option value="Europe/Madrid">Іспанія (Europe/Madrid)</option>
                    <option value="Europe/Rome">Італія (Europe/Rome)</option>
                    <option value="Europe/Belgrade">Сербія (Europe/Belgrade)</option>
                    <option value="Europe/Skopje">Північна Македонія (Europe/Skopje)</option>
                    <option value="Europe/Sarajevo">Боснія і Герцеговина (Europe/Sarajevo)</option>
                    <option value="Europe/Zagreb">Хорватія (Europe/Zagreb)</option>
                    <option value="Europe/Ljubljana">Словенія (Europe/Ljubljana)</option>
                    <option value="Europe/Bratislava">Словаччина (Europe/Bratislava)</option>
                    <option value="Europe/Paris">Франція (Europe/Paris)</option>
                    <option value="Europe/London">Велика Британія (Europe/London)</option>
                    <option value="Europe/Berlin">Німеччина (Europe/Berlin)</option>
                    <option value="America/New_York">США, Нью-Йорк (America/New_York)</option>
                    <option value="America/Los_Angeles">США, Лос-Анджелес (America/Los_Angeles)</option>
                    <option value="Asia/Tokyo">Японія (Asia/Tokyo)</option>
                    <option value="Australia/Sydney">Австралія (Australia/Sydney)</option>
                </select>
                <button type="button" id="add-timezone-btn" class="btn btn-warning">Додати</button>
            </div>
            <div id="timezone-list" class="home-timezone-list"></div>
        </article>
    </div>
    </section>
</div>

