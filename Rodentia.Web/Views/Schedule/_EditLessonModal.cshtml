@using Rodentia.Core.Entities
@model Rodentia.Web.Models.Lessons.EditLessonModalViewModel

<div class="lesson-modal-overlay" id="edit-lesson-modal-overlay">
    <div class="lesson-modal-window" role="dialog" aria-modal="true">
        <div class="lesson-modal-header">
            <span>Редагувати заняття</span>
            <button type="button" class="lesson-modal-close" data-lesson-close>&times;</button>
        </div>
        <form id="edit-lesson-form"
              asp-controller="Schedule"
              asp-action="EditLesson"
              method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="LessonId" />

            <div class="lesson-modal-body">
                <div class="lesson-form-errors" id="edit-lesson-form-errors"></div>

                <div class="mb-3">
                    <label asp-for="StudentId" class="form-label">Учень</label>
                    <select asp-for="StudentId" asp-items="Model.StudentOptions" class="form-select">
                        <option value="">Оберіть учня</option>
                    </select>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="LessonDate" class="form-label">Дата</label>
                        <input asp-for="LessonDate" type="date" class="form-control" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="StartTime" class="form-label">Початок</label>
                        <input asp-for="StartTime" type="time" class="form-control" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="DurationMinutes" class="form-label">Тривалість (хв)</label>
                        <input asp-for="DurationMinutes" type="number" min="1" class="form-control" />
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Subject" class="form-label">Дисципліна</label>
                    <input asp-for="Subject" class="form-control" />
                </div>
                <div class="mb-3">
                    <label asp-for="Topic" class="form-label">Тема</label>
                    <input asp-for="Topic" class="form-control" />
                </div>

                <div class="row align-items-end mb-3">
                    <div class="col-md-4">
                        <label asp-for="Price" class="form-label">Ціна</label>
                        <input asp-for="Price" type="number" step="0.01" min="0" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Status" class="form-label">Статус заняття</label>
                        <select asp-for="Status" class="form-select">
                            <option value="@((int)LessonStatus.Scheduled)">Заплановано</option>
                            <option value="@((int)LessonStatus.Completed)">Проведено</option>
                            <option value="@((int)LessonStatus.Canceled)">Скасовано</option>
                        </select>
                    </div>
                    <div class="col-md-4 d-flex align-items-center pt-3">
                        <input asp-for="IsPaid" type="checkbox" id="edit-is-paid-checkbox" class="d-none" />
                        <button type="button"
                                id="edit-is-paid-btn"
                                class="btn w-100 @(Model.IsPaid ? "btn-success" : "btn-outline-secondary")"
                                onclick="toggleIsPaid()">
                            @if (Model.IsPaid)
                            {
                                <i class="bi bi-check-circle-fill me-1"></i>
                            
                                <span>Оплачено</span>
                            }
                            else
                            {
                                <i class="bi bi-circle me-1"></i>
                            
                                <span>Не оплачено</span>
                            }
                        </button>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Notes" class="form-label">Нотатки</label>
                    <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                </div>
                <div class="mb-3">
                    <label asp-for="Homework" class="form-label">Домашнє завдання</label>
                    <textarea asp-for="Homework" class="form-control" rows="2"
                              placeholder="Умова домашнього завдання для учня..."></textarea>
                </div>
                <div class="mb-3">
                    <label asp-for="MaterialLinks" class="form-label">Матеріали та посилання</label>
                    <textarea asp-for="MaterialLinks" class="form-control" rows="2"
                              placeholder="https://drive.google.com/... (кожне посилання з нового рядка)"></textarea>
                </div>
                <div class="mb-3">
                    <label asp-for="ProgressNote" class="form-label">Успіхи та проблеми учня</label>
                    <textarea asp-for="ProgressNote" class="form-control" rows="2"
                              placeholder="Опишіть успіхи та проблеми учня на занятті..."></textarea>
                </div>

                <hr />
                <div id="reschedule-section" data-lesson-id="@Model.LessonId">
                    <h6 class="fw-bold">Запит на перенесення</h6>
                    <div class="row g-2">
                        <div class="col-md-4">
                            <label class="form-label">Нова дата</label>
                            <input type="date" id="reschedule-date" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Новий час</label>
                            <input type="time" id="reschedule-time" class="form-control" />
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <button type="button" id="create-reschedule-btn" class="btn btn-outline-warning w-100">Створити запит</button>
                        </div>
                    </div>
                    <div class="mt-2">
                        <label class="form-label">Причина</label>
                        <textarea id="reschedule-reason" class="form-control" rows="2" placeholder="Наприклад: зайнятий у цей час"></textarea>
                    </div>
                    <div id="reschedule-errors" class="text-danger small mt-2"></div>
                    <div id="reschedule-requests-list" class="mt-3"></div>
                </div>
            </div>

            <div class="lesson-modal-footer">
                <button type="submit" class="btn btn-warning">Оновити</button>
                <button type="button"
                        class="btn btn-danger"
                        onclick="requestDeleteLesson('@Model.LessonId')">
                    Видалити
                </button>
                <button type="button" class="btn btn-secondary" data-lesson-close>Скасувати</button>
            </div>
        </form>
    </div>
</div>

