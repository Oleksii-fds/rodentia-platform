@model ErrorViewModel
@{
    ViewData["Title"] = "Помилка";
}

<div class="text-center mt-5">
    <h1 class="text-danger"><i class="bi bi-exclamation-triangle"></i> Виникла помилка</h1>
    <hr />

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert alert-warning shadow-sm">
            <h4 class="alert-heading">Деталі помилки:</h4>
            <p class="mb-0">@Model.Message</p>
        </div>
    }
    else
    {
        <h2 class="text-muted">Під час обробки вашого запиту сталася непередбачувана помилка.</h2>
    }

    @if (Model.ShowRequestId)
    {
        <div class="mt-4">
            <p class="text-secondary">
                <strong>ID запиту для служби підтримки:</strong> 
                <code class="bg-light p-1 rounded">@Model.RequestId</code>
            </p>
        </div>
    }

    <div class="mt-5">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg">
            Повернутися на головну
        </a>
    </div>
</div>

