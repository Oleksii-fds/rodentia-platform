<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Rodentia - @ViewData["Title"]</title>
    <link rel="stylesheet" href="~/bundles/site.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body>
    <div class="sidebar">
        <a asp-controller="Home" asp-action="Index" class="logo-text text-decoration-none d-block mb-4">Rodentia</a>
        <nav class="nav flex-column">
            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Schedule" ? "active-orange" : "")"
               asp-controller="Schedule" asp-action="Index">
                <i class="bi bi-calendar3 me-2"></i> Розклад
            </a>
            @if (User.IsInRole("Teacher"))
            {
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Teacher" ? "active-orange" : "")"
                   asp-controller="Teacher" asp-action="MyStudents">
                    <i class="bi bi-people me-2"></i> Мої учні
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Debt" ? "active-orange" : "")"
                   asp-controller="Debt" asp-action="Index">
                    <i class="bi bi-cash-coin me-2"></i> Борги
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "TeacherLessonHistory" ? "active-orange" : "")"
                   asp-controller="TeacherLessonHistory" asp-action="Index">
                    <i class="bi bi-clock-history me-2"></i> Історія уроків
                </a>
            }
            @if (User.IsInRole("Student"))
            {
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "StudentPayments" ? "active-orange" : "")"
                   asp-controller="StudentPayments" asp-action="Index">
                    <i class="bi bi-wallet2 me-2"></i> Оплата
                </a>
            }
        </nav>
    </div>

    <div class="main-content">
        <header class="d-flex justify-content-end align-items-center mb-4 p-2">
            @{
                var firstName = User.FindFirst("FirstName")?.Value ?? "";
                var lastName = User.FindFirst("LastName")?.Value ?? "";
                var avatarPath = User.FindFirst("AvatarPath")?.Value;
                var displayName = string.IsNullOrWhiteSpace($"{firstName} {lastName}".Trim())
                ? User.Identity?.Name
                : $"{firstName} {lastName}".Trim();
                var roleLabel = User.IsInRole("Teacher") ? "Викладач" : "Учень";
                var initial = (!string.IsNullOrWhiteSpace(firstName)
                ? firstName[0]
                : User.Identity?.Name?[0] ?? '?').ToString().ToUpper();
            }

            <div class="dropdown me-3">
                <button class="btn btn-light border notification-bell-btn"
                        type="button" id="notificationsDropdown"
                        data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-bell"></i>
                    <span id="notification-badge" class="bg-danger text-white notification-badge d-none">0</span>
                </button>
                <div class="dropdown-menu dropdown-menu-end notification-menu" aria-labelledby="notificationsDropdown">
                    <div class="px-3 py-2 fw-bold border-bottom">Сповіщення</div>
                    <div id="notification-list">
                        <div class="px-3 py-2 text-muted small">Завантаження...</div>
                    </div>
                </div>
            </div>

            <form id="notifications-antiforgery-form" asp-controller="Notifications" asp-action="MarkAsRead" method="post" class="d-none">
                @Html.AntiForgeryToken()
            </form>

            <div class="d-flex align-items-center gap-2 me-3">
                @if (!string.IsNullOrWhiteSpace(avatarPath))
                {
                    <img src="@avatarPath" alt="Аватар" class="navbar-avatar" id="navbar-avatar-img" />
                }
                else
                {
                    <div class="navbar-avatar-placeholder" id="navbar-avatar-placeholder">@initial</div>
                }
                <div class="text-end">
                    <div class="fw-bold lh-1">@displayName</div>
                    <small class="text-muted">@roleLabel</small>
                </div>
            </div>

            <button type="button" id="open-profile-modal" class="btn btn-warning me-2">
                Профіль
            </button>

            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-light border">Вихід</button>
            </form>
        </header>

        <div id="profile-modal-root"></div>
        <main role="main">@RenderBody()</main>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="~/bundles/site.min.js" asp-append-version="true"></script>
</body>
</html>
