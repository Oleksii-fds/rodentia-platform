<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Rodentia - @ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/profile-modal.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root { --rodentia-orange: #FF6B00; --rodentia-light: #FFF8F4; }
        body { background-color: white; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .sidebar { width: 200px; height: 100vh; position: fixed; border-right: 1px solid #eee; padding: 20px; }
        .main-content { margin-left: 200px; padding: 20px; background-color: white; min-height: 100vh; }
        .nav-link.active-orange { background-color: var(--rodentia-orange) !important; color: white !important; border-radius: 8px; }
        .nav-link { color: #333; margin-bottom: 10px; font-weight: 500; }
        .logo-text { color: var(--rodentia-orange); font-size: 24px; font-weight: 800; margin-bottom: 30px; }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="logo-text">Rodentia</div>
        <nav class="nav flex-column">
            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Schedule" ? "active-orange" : "")" 
            asp-controller="Schedule" asp-action="Index">
                <i class="bi bi-calendar3 me-2"></i> Розклад
            </a>

            @if (User.IsInRole("Teacher"))
            {
                <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Teacher" ? "active-orange" : "")" 
                asp-controller="Teacher" asp-action="MyStudents">
                    <i class="bi bi-people me-2"></i> Мої учні
                </a>
            }

            <a class="nav-link" href="#"><i class="bi bi-clock-history me-2"></i> Історія занять</a>
        </nav>
    </div>

    <div class="main-content">
        <header class="d-flex justify-content-end align-items-center mb-4 p-2">
            <div class="d-flex align-items-center me-3 text-end">
                <div class="me-2">
                    <div class="fw-bold">
                    @User.Identity?.Name 
                    (@(User.IsInRole("Teacher") ? "Викладач" : "Учень"))
                </div>
                    <small class="text-muted">@User.Identity?.Name</small>
                </div>
                <div class="bg-secondary rounded-circle d-flex align-items-center justify-content-center text-white fw-bold" style="width: 40px; height: 40px;">
                    @(User.Identity?.Name?[0].ToString().ToUpper() ?? "?")
                </div>

            </div>
            
            <button type="button" id="open-profile-modal" class="btn btn-warning me-2">
                Профіль
            </button>
            
            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-light border">Вихід</button>
            </form>
        </header>

        <div id="profile-modal-root"></div>

        <main role="main">
            @RenderBody()
        </main>
    </div> <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/profile-modal.js" asp-append-version="true"></script>
</body>
</html>
