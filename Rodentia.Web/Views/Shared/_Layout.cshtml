<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Rodentia - @ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root { --rodentia-orange: #FF6B00; --rodentia-light: #FFF8F4; }
        body { background-color: white; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .sidebar { width: 200px; height: 100vh; position: fixed; border-right: 1px solid #eee; padding: 20px; }
        .main-content { margin-left: 200px; padding: 20px; background-color: white; min-height: 100vh; }
        .nav-link.active-orange { background-color: var(--rodentia-orange) !important; color: white !important; border-radius: 8px; }
        .nav-link { color: #333; margin-bottom: 10px; font-weight: 500; }
        .logo-text { color: var(--rodentia-orange); font-size: 24px; font-weight: 800; margin-bottom: 30px; }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="logo-text">Rodentia</div>
        <nav class="nav flex-column">
            <a class="nav-link active-orange" asp-controller="Schedule" asp-action="Index">Розклад</a>
            <a class="nav-link" href="#">Історія занять</a>
        </nav>
    </div>

    <div class="main-content">
        <header class="d-flex justify-content-end align-items-center mb-4 p-2">
            <div class="d-flex align-items-center me-3 text-end">
                <div class="me-2">
                    <div class="fw-bold">@User.Identity?.Name (Учень)</div>
                    <small class="text-muted">@User.Identity?.Name@@gmail.com</small>
                </div>
                <div class="bg-secondary rounded-circle" style="width: 40px; height: 40px;"></div>
            </div>
            <button class="btn btn-warning text-white me-2">Профіль</button>
            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-light border">Вихід</button>
            </form>
        </header>

        <main role="main">
            @RenderBody()
        </main>
    </div>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
